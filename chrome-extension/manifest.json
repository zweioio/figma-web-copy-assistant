
{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.1",
  "description": "__MSG_appDesc__",
  "default_locale": "zh_CN",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "official-capture.js", 
        "official-capture-en.js", 
        "trigger.js", 
        "icons/*.png",
        "icons/*.svg"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
